# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Adresse qui reçoit les soumissions du formulaire de contact
CONTACT_EMAIL_TO=

# Adresse expéditrice (doit être un domaine vérifié dans Resend)
CONTACT_EMAIL_FROM=

# URL publique du site (utilisée pour les meta SEO et le sitemap)
PUBLIC_SITE_URL=
