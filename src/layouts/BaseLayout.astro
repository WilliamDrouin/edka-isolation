---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Si vrai, le Header est transparent par-dessus le contenu (pour les pages avec hero sombre) */
  transparentHeader?: boolean;
}

const {
  title,
  description = 'Isolation EDKA — Spécialiste en isolation à Saint-Georges-de-Beauce. Uréthane giclé, cellulose, fibre de verre. Soumission gratuite.',
  transparentHeader = false,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://isolation-edka.ca';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL('/images/logoprincipale.jpg', siteUrl).toString();

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteUrl}/#business`,
  name: 'Isolation EDKA inc.',
  alternateName: 'Isolation EDKA',
  description:
    "Entreprise locale en Beauce spécialisée en uréthane giclé. Solutions d'isolation durables et performantes pour résidentiel, commercial et agricole. Licence RBQ 5790-3981-01.",
  url: siteUrl,
  logo: ogImage,
  image: ogImage,
  telephone: '+1-418-000-0000',
  email: 'info@isolation-edka.ca',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '13650 59e Avenue',
    addressLocality: 'Saint-Georges',
    addressRegion: 'QC',
    postalCode: 'G5Y 5B9',
    addressCountry: 'CA',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 46.11,
    longitude: -70.68,
  },
  sameAs: ['https://www.facebook.com/Isolationedka'],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Saint-Georges-de-Beauce' },
    { '@type': 'AdministrativeArea', name: 'Beauce-Sartigan' },
    { '@type': 'AdministrativeArea', name: 'La Guadeloupe' },
    { '@type': 'AdministrativeArea', name: 'Chaudière-Appalaches' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '07:30',
      closes: '17:00',
    },
  ],
  knowsAbout: [
    'Uréthane giclé',
    'Isolation de sous-sol',
    "Isolation d'entretoit",
    'Efficacité énergétique',
    'Confort thermique',
    'Isolation résidentielle',
    'Isolation commerciale',
    'Isolation agricole',
    'Programme Rénoclimat',
    'Programme LogisVert',
  ],
  identifier: {
    '@type': 'PropertyValue',
    name: 'RBQ',
    value: '5790-3981-01',
  },
};
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F172A" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Isolation EDKA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <noscript>
      <style>
        [data-reveal],
        [data-stagger] > * {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>

    <ClientRouter />
  </head>
  <body>
    <Header transparent={transparentHeader} />
    <main id="contenu">
      <slot />
    </main>
    <Footer />

    <script>
      import { animate, inView } from 'motion';

      const easeOut: [number, number, number, number] = [0.16, 1, 0.3, 1];

      const animateReveal = (el: HTMLElement, delay = 0): void => {
        animate(
          el,
          { opacity: [0, 1], transform: ['translate3d(0, 24px, 0)', 'translate3d(0, 0, 0)'] },
          { duration: 0.85, delay, ease: easeOut },
        );
      };

      const initReveal = (root: ParentNode = document): void => {
        // Éléments simples [data-reveal]
        root.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
          if (el.dataset.revealInit === 'true') return;
          el.dataset.revealInit = 'true';
          const delay = Number(el.dataset.revealDelay ?? '0') / 1000;
          inView(el, () => animateReveal(el, delay), { amount: 0.18 });
        });

        // Stagger pour [data-stagger] : anime les enfants un à un
        root.querySelectorAll<HTMLElement>('[data-stagger]').forEach((parent) => {
          if (parent.dataset.staggerInit === 'true') return;
          parent.dataset.staggerInit = 'true';
          const children = Array.from(parent.children) as HTMLElement[];
          const step = Number(parent.dataset.staggerStep ?? '90') / 1000;
          inView(
            parent,
            () => {
              children.forEach((child, idx) => animateReveal(child, idx * step));
            },
            { amount: 0.12 },
          );
        });
      };

      const reset = (root: ParentNode = document): void => {
        root.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
          delete el.dataset.revealInit;
        });
        root.querySelectorAll<HTMLElement>('[data-stagger]').forEach((el) => {
          delete el.dataset.staggerInit;
        });
      };

      initReveal();

      // Re-init après navigation via Astro view transitions
      document.addEventListener('astro:after-swap', () => {
        reset();
        initReveal();
      });
    </script>
  </body>
</html>
