---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Si vrai, le Header est transparent par-dessus le contenu (pour les pages avec hero sombre) */
  transparentHeader?: boolean;
}

const {
  title,
  description = 'Isolation EDKA — Spécialiste en isolation à Saint-Georges-de-Beauce. Uréthane giclé, cellulose, fibre de verre. Soumission gratuite.',
  transparentHeader = false,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://isolation-edka.ca';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL('/images/logoprincipale.jpg', siteUrl).toString();
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F172A" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Isolation EDKA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <Header transparent={transparentHeader} />
    <main id="contenu">
      <slot />
    </main>
    <Footer />
  </body>
</html>
