---
import { getCollection } from 'astro:content';
import { iconPaths } from '../../lib/icons';

const services = (await getCollection('services')).sort((a, b) => a.data.ordre - b.data.ordre);
---

<section id="services" class="container-page py-20 sm:py-28">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <p class="text-[color:var(--color-brand-600)] text-sm font-semibold tracking-widest uppercase">
      Nos services
    </p>
    <h2 class="font-display mt-3 text-3xl font-bold sm:text-4xl">
      L'uréthane giclé, et tout ce qui rend une maison performante.
    </h2>
    <p class="text-muted-foreground mt-4 text-lg">
      Notre spécialité, c'est l'uréthane. Mais on vous accompagne aussi sur l'enveloppe au complet
      — sous-sol, entretoit, efficacité énergétique et confort thermique.
    </p>
  </div>

  <ul
    class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
    data-stagger
    data-stagger-step="80"
  >
    {
      services.map((service) => (
        <li>
          <a
            href={`/services#${service.id}`}
            class:list={[
              'group bg-card relative flex h-full flex-col rounded-xl border p-6 transition-all',
              'hover:border-[color:var(--color-brand-400)] hover:shadow-lg hover:-translate-y-0.5',
              'focus-visible:ring-2 focus-visible:ring-[color:var(--color-brand-400)] focus-visible:outline-none',
              service.data.specialite ? 'ring-1 ring-[color:var(--color-brand-200)]' : '',
            ]}
          >
            {service.data.specialite && (
              <span class="bg-[color:var(--color-brand-600)] absolute -top-2 right-6 inline-flex items-center rounded-full px-3 py-0.5 text-xs font-semibold text-white">
                Spécialité
              </span>
            )}
            <span
              class="bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-600)] inline-flex h-12 w-12 items-center justify-center rounded-lg"
              aria-hidden="true"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={iconPaths[service.data.icone]} />
              </svg>
            </span>
            <h3 class="font-display mt-5 text-xl font-semibold">{service.data.titre}</h3>
            <p class="text-muted-foreground mt-2 flex-1 text-sm leading-relaxed">
              {service.data.descriptionCourte}
            </p>
            <span
              class="text-[color:var(--color-brand-600)] mt-5 inline-flex items-center gap-1 text-sm font-semibold"
              aria-hidden="true"
            >
              En savoir plus
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform group-hover:translate-x-0.5"
              >
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
