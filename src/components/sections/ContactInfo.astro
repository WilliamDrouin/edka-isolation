---
const coordonnees = [
  {
    icon: 'phone',
    label: 'Téléphone',
    value: '(418) 000-0000',
    href: 'tel:0000000000',
  },
  {
    icon: 'mail',
    label: 'Courriel',
    value: 'info@isolation-edka.ca',
    href: 'mailto:info@isolation-edka.ca',
  },
  {
    icon: 'map-pin',
    label: 'Adresse',
    value: '13650 59e Avenue, Saint-Georges, QC G5Y 5B9',
  },
  {
    icon: 'clock',
    label: 'Heures d\'ouverture',
    value: 'Lun. au ven. 7 h 30 — 17 h',
  },
] as const;

const iconPaths = {
  phone:
    'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z',
  mail: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
  'map-pin': 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6z',
  clock: 'M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M12 6v6l4 2',
};

// Bbox pour OpenStreetMap centré sur Saint-Georges-de-Beauce
const osmEmbedSrc =
  'https://www.openstreetmap.org/export/embed.html?bbox=-70.7150%2C46.0850%2C-70.6450%2C46.1350&layer=mapnik&marker=46.1100%2C-70.6800';
const osmFullLink = 'https://www.openstreetmap.org/?mlat=46.1100&mlon=-70.6800#map=13/46.1100/-70.6800';
---

<aside class="space-y-8">
  <div class="border-border bg-muted/30 rounded-2xl border p-6 sm:p-8">
    <h2 class="font-display text-xl font-semibold">Joignez-nous directement.</h2>
    <p class="text-muted-foreground mt-2 text-sm">
      Pour les questions urgentes ou si vous préférez parler à quelqu'un.
    </p>
    <ul class="mt-6 space-y-5">
      {
        coordonnees.map((item) => (
          <li class="flex items-start gap-4">
            <span
              class="bg-card text-[color:var(--color-brand-600)] inline-flex h-10 w-10 flex-none items-center justify-center rounded-md border"
              aria-hidden="true"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={iconPaths[item.icon]} />
              </svg>
            </span>
            <div>
              <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
                {item.label}
              </p>
              {'href' in item ? (
                <a
                  href={item.href}
                  class="text-foreground hover:text-[color:var(--color-brand-700)] mt-1 block text-base font-medium transition-colors"
                >
                  {item.value}
                </a>
              ) : (
                <p class="text-foreground mt-1 text-base font-medium">{item.value}</p>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="border-border overflow-hidden rounded-2xl border shadow-sm">
    <iframe
      src={osmEmbedSrc}
      title="Carte de Saint-Georges-de-Beauce"
      loading="lazy"
      class="aspect-square w-full sm:aspect-video"
      style="border:0;"
    >
    </iframe>
    <div class="bg-card flex items-center justify-between gap-3 border-t px-4 py-3 text-xs">
      <span class="text-muted-foreground">Saint-Georges-de-Beauce, QC</span>
      <a
        href={osmFullLink}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[color:var(--color-brand-600)] hover:text-[color:var(--color-brand-700)] inline-flex items-center gap-1 font-semibold transition-colors"
      >
        Voir en grand
        <svg
          aria-hidden="true"
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M7 7h10v10M7 17 17 7" />
        </svg>
      </a>
    </div>
  </div>
</aside>
