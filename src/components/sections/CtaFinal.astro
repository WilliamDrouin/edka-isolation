---
import { Image } from 'astro:assets';
import chantier from '../../assets/images/realisations/chantieretecommehiver.jpg';
---

<section id="cta-final" class="dark text-foreground bg-background relative isolate overflow-hidden">
  <Image
    src={chantier}
    alt=""
    aria-hidden="true"
    widths={[640, 1280, 1920]}
    sizes="100vw"
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-25"
    loading="lazy"
  />
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-r from-slate-950 via-slate-950/95 to-slate-950/70"
    aria-hidden="true"
  >
  </div>

  <div class="container-page py-20 sm:py-28">
    <div class="max-w-3xl" data-reveal>
      <h2 class="font-display text-3xl font-bold sm:text-4xl lg:text-5xl">
        Prêt à passer à l'isolation qui dure ?
      </h2>
      <p class="mt-4 text-lg text-slate-300">
        On évalue votre projet gratuitement, on identifie les subventions admissibles, et on vous
        revient avec une soumission claire.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="/contact"
          class="bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-400)] focus-visible:ring-[color:var(--color-brand-300)] inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 text-base font-semibold text-slate-950 transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950 focus-visible:outline-none"
        >
          Demander une soumission gratuite
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="tel:0000000000"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-white/30 bg-white/5 px-6 py-3 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/10"
        >
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          (418) 000-0000
        </a>
      </div>
    </div>
  </div>
</section>
