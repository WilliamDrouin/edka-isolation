---
const programmes = [
  { nom: 'Rénoclimat', description: 'Évaluation énergétique + remboursement des travaux admissibles.' },
  { nom: 'LogisVert', description: 'Subvention Hydro-Québec pour les améliorations de l\'enveloppe.' },
  { nom: 'Chauffez vert', description: 'Conversion de systèmes de chauffage au mazout vers l\'électricité.' },
] as const;
---

<section id="subventions-teaser" class="bg-muted/40 border-y border-[color:var(--border)]">
  <div class="container-page py-20 sm:py-28">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.4fr] lg:items-center">
      <div>
        <p class="text-[color:var(--color-brand-600)] text-sm font-semibold tracking-widest uppercase">
          Subventions disponibles
        </p>
        <h2 class="font-display mt-3 text-3xl font-bold sm:text-4xl">
          Vos travaux peuvent être en partie remboursés.
        </h2>
        <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
          On vous accompagne dans le processus : évaluation énergétique, choix des programmes,
          paperasse. Vous récupérez les chèques ; nous, on s'occupe de l'isolation.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/subventions"
            class="bg-[color:var(--color-brand-600)] hover:bg-[color:var(--color-brand-500)] focus-visible:ring-[color:var(--color-brand-400)] inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-sm font-semibold text-white transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
          >
            Voir les programmes admissibles
            <svg
              aria-hidden="true"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/contact"
            class="border-border hover:bg-muted inline-flex items-center justify-center gap-2 rounded-md border bg-transparent px-5 py-3 text-sm font-semibold transition-colors"
          >
            Vérifier mon admissibilité
          </a>
        </div>
      </div>

      <ul class="grid gap-4 sm:grid-cols-3 lg:gap-6">
        {
          programmes.map((p) => (
            <li class="bg-card flex h-full flex-col rounded-xl border p-5">
              <span
                class="bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-700)] inline-flex h-10 w-10 items-center justify-center rounded-md"
                aria-hidden="true"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              </span>
              <h3 class="font-display mt-4 text-lg font-semibold">{p.nom}</h3>
              <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{p.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
