---
import { mainNav } from '../lib/navigation';

const year = new Date().getFullYear();

const services = [
  { label: 'Uréthane giclé', href: '/services#01-urethane-gicle' },
  { label: 'Isolation de sous-sol', href: '/services#02-sous-sol' },
  { label: "Isolation d'entretoit", href: '/services#03-entretoit' },
  { label: 'Efficacité énergétique', href: '/services#04-efficacite-energetique' },
  { label: 'Confort thermique', href: '/services#05-confort-thermique' },
] as const;

const coordonnees = {
  raisonSociale: 'Isolation EDKA inc.',
  adresseLigne1: '13650 59e Avenue',
  adresseLigne2: 'Saint-Georges, QC G5Y 5B9',
  region: 'Beauce · Chaudière-Appalaches',
  telephone: '(418) 000-0000',
  courriel: 'info@isolation-edka.ca',
  rbq: 'RBQ : 5790-3981-01',
  facebook: 'https://www.facebook.com/Isolationedka',
} as const;
---

<footer class="dark bg-background text-foreground">
  <div class="container-page py-16">
    <div class="grid gap-10 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center" aria-label="Accueil — Isolation EDKA">
          <img src="/images/logoprincipale.jpg" alt="Isolation EDKA" class="h-14 w-auto" />
        </a>
        <p class="text-muted-foreground mt-4 text-sm leading-relaxed">
          Entreprise locale en Beauce, spécialisée en uréthane giclé. Solutions d'isolation
          durables et performantes pour résidentiel, commercial et agricole.
        </p>
        <div class="mt-5">
          <a
            href={coordonnees.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Suivez-nous sur Facebook"
            class="text-muted-foreground hover:text-[color:var(--color-brand-400)] inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/15 transition-colors hover:border-[color:var(--color-brand-400)]"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold tracking-wide uppercase">Navigation</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            mainNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold tracking-wide uppercase">Services</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            services.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold tracking-wide uppercase">Coordonnées</h2>
        <address class="text-muted-foreground mt-4 space-y-2 text-sm not-italic">
          <p class="text-foreground font-medium">{coordonnees.raisonSociale}</p>
          <p>{coordonnees.adresseLigne1}</p>
          <p>{coordonnees.adresseLigne2}</p>
          <p class="text-muted-foreground/80">{coordonnees.region}</p>
          <p>
            <a
              href={`tel:${coordonnees.telephone.replace(/\D/g, '')}`}
              class="hover:text-foreground transition-colors"
            >
              {coordonnees.telephone}
            </a>
          </p>
          <p>
            <a
              href={`mailto:${coordonnees.courriel}`}
              class="hover:text-foreground transition-colors"
            >
              {coordonnees.courriel}
            </a>
          </p>
          <p class="text-[color:var(--color-brand-300)] pt-2 font-mono text-xs">
            {coordonnees.rbq}
          </p>
        </address>
      </div>
    </div>

    <div
      class="border-border/40 text-muted-foreground mt-12 flex flex-col gap-4 border-t pt-6 text-xs sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Isolation EDKA inc. Tous droits réservés.</p>
      <p>
        Fier partenaire des
        <a
          href="https://jaysbeaucesud.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[color:var(--color-brand-400)] hover:text-[color:var(--color-brand-300)] transition-colors"
        >
          Jays du Sud de la Beauce
        </a>
        .
      </p>
    </div>
  </div>
</footer>
