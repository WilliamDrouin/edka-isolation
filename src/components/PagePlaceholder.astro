---
interface Props {
  titre: string;
  surtitre?: string;
  description: string;
}

const { titre, surtitre, description } = Astro.props;
---

<section class="container-page py-24 sm:py-32">
  {
    surtitre && (
      <p class="text-[color:var(--color-brand-600)] text-sm font-semibold tracking-widest uppercase">
        {surtitre}
      </p>
    )
  }
  <h1 class="font-display mt-3 text-4xl font-bold sm:text-5xl">{titre}</h1>
  <p class="text-muted-foreground mt-4 max-w-2xl text-lg">{description}</p>
  <div
    class="border-border bg-muted text-muted-foreground mt-12 rounded-xl border p-8 text-sm"
    role="status"
  >
    <strong class="text-foreground">Page en construction.</strong> Le contenu sera ajouté à l'Étape 3.3.
  </div>
</section>
