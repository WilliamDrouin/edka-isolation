---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const realisations = await getCollection('realisations');
  return realisations.map((projet) => ({
    params: { slug: projet.id },
    props: { projet },
  }));
}

const { projet } = Astro.props;
const { Content } = await render(projet);

const categorieLabels = {
  residentiel: 'Résidentiel',
  commercial: 'Commercial',
  agricole: 'Agricole',
  industriel: 'Industriel',
  vehicules: 'Véhicules',
} as const;

const formatNumber = (n: number): string => n.toLocaleString('fr-CA');
---

<BaseLayout
  title={`${projet.data.titre} — Isolation EDKA`}
  description={projet.data.resume}
>
  <article>
    <header class="bg-muted/40 border-b">
      <div class="container-page py-12 sm:py-16">
        <nav aria-label="Fil d'Ariane" class="text-muted-foreground mb-6 text-sm">
          <ol class="flex flex-wrap gap-2">
            <li><a href="/" class="hover:text-foreground">Accueil</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/realisations" class="hover:text-foreground">Réalisations</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-foreground" aria-current="page">{projet.data.titre}</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-3 text-sm">
          <span class="bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-700)] inline-flex items-center rounded-md px-3 py-1 font-semibold tracking-wide uppercase">
            {categorieLabels[projet.data.categorie]}
          </span>
          <span class="text-muted-foreground">
            {projet.data.ville} · {projet.data.annee}
          </span>
          {
            projet.data.superficiePiedsCarres && (
              <span class="text-muted-foreground">
                {formatNumber(projet.data.superficiePiedsCarres)} pi²
              </span>
            )
          }
        </div>
        <h1 class="font-display mt-4 max-w-3xl text-3xl font-bold sm:text-4xl lg:text-5xl">
          {projet.data.titre}
        </h1>
        <p class="text-muted-foreground mt-4 max-w-2xl text-lg leading-relaxed">
          {projet.data.resume}
        </p>
      </div>
    </header>

    <div class="container-page py-16 sm:py-20">
      <figure class="overflow-hidden rounded-2xl shadow-xl ring-1 ring-black/5">
        <Image
          src={projet.data.photoPrincipale}
          alt={projet.data.photoPrincipaleAlt}
          widths={[640, 1024, 1440, 1920]}
          sizes="(min-width: 1024px) 1024px, 100vw"
          class="h-auto w-full object-cover"
          loading="eager"
        />
      </figure>

      {
        projet.data.stats && (
          <dl class="border-border bg-muted/30 mt-10 grid gap-6 rounded-2xl border p-6 sm:grid-cols-3 sm:p-8">
            {projet.data.stats.economiesPercent !== undefined && (
              <div>
                <dt class="text-muted-foreground text-xs font-semibold tracking-widest uppercase">
                  Économies de chauffage
                </dt>
                <dd class="font-display text-[color:var(--color-brand-600)] mt-2 text-4xl font-bold">
                  {projet.data.stats.economiesPercent}%
                </dd>
              </div>
            )}
            {projet.data.stats.valeurRAtteinte && (
              <div>
                <dt class="text-muted-foreground text-xs font-semibold tracking-widest uppercase">
                  Valeur R atteinte
                </dt>
                <dd class="font-display text-foreground mt-2 text-2xl font-bold">
                  {projet.data.stats.valeurRAtteinte}
                </dd>
              </div>
            )}
            {projet.data.stats.dureeChantier && (
              <div>
                <dt class="text-muted-foreground text-xs font-semibold tracking-widest uppercase">
                  Durée du chantier
                </dt>
                <dd class="font-display text-foreground mt-2 text-2xl font-bold">
                  {projet.data.stats.dureeChantier}
                </dd>
              </div>
            )}
          </dl>
        )
      }

      <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
        <div class="prose prose-slate text-foreground/90 max-w-none">
          <Content />
        </div>
        <aside class="space-y-6">
          <div class="border-border bg-card rounded-xl border p-6">
            <h2 class="font-display text-sm font-semibold tracking-wide uppercase">
              Techniques utilisées
            </h2>
            <ul class="mt-3 space-y-2 text-sm">
              {
                projet.data.typesIsolation.map((type) => (
                  <li class="flex gap-2">
                    <svg
                      class="text-[color:var(--color-brand-600)] mt-0.5 h-4 w-4 flex-none"
                      aria-hidden="true"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    <span>{type}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="bg-[color:var(--color-brand-600)] rounded-xl p-6 text-white">
            <h2 class="font-display text-lg font-semibold">Un projet similaire ?</h2>
            <p class="mt-2 text-sm text-white/90">
              Décrivez-nous votre situation et on revient avec une soumission gratuite.
            </p>
            <a
              href="/contact"
              class="mt-4 inline-flex items-center gap-2 rounded-md bg-white px-4 py-2 text-sm font-semibold text-[color:var(--color-brand-700)] transition-colors hover:bg-slate-100"
            >
              Demander une soumission
              <svg
                aria-hidden="true"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </aside>
      </div>

      {
        projet.data.avantApres && (
          <section class="mt-16">
            <h2 class="font-display text-2xl font-bold sm:text-3xl">Avant / après</h2>
            {projet.data.avantApres.legende && (
              <p class="text-muted-foreground mt-2">{projet.data.avantApres.legende}</p>
            )}
            <div class="mt-6 grid gap-6 sm:grid-cols-2">
              <figure class="overflow-hidden rounded-xl border shadow-sm">
                <Image
                  src={projet.data.avantApres.avant}
                  alt={`Avant les travaux — ${projet.data.titre}`}
                  widths={[480, 720, 960]}
                  sizes="(min-width: 640px) 50vw, 100vw"
                  class="aspect-4/3 h-full w-full object-cover"
                  loading="lazy"
                />
                <figcaption class="bg-muted px-4 py-2 text-center text-sm font-semibold">
                  AVANT
                </figcaption>
              </figure>
              <figure class="overflow-hidden rounded-xl border shadow-sm">
                <Image
                  src={projet.data.avantApres.apres}
                  alt={`Après les travaux — ${projet.data.titre}`}
                  widths={[480, 720, 960]}
                  sizes="(min-width: 640px) 50vw, 100vw"
                  class="aspect-4/3 h-full w-full object-cover"
                  loading="lazy"
                />
                <figcaption class="bg-[color:var(--color-brand-600)] px-4 py-2 text-center text-sm font-semibold text-white">
                  APRÈS
                </figcaption>
              </figure>
            </div>
          </section>
        )
      }
    </div>

    <nav class="bg-muted/40 border-t" aria-label="Autres réalisations">
      <div class="container-page py-12 sm:py-16">
        <a
          href="/realisations"
          class="text-[color:var(--color-brand-600)] hover:text-[color:var(--color-brand-700)] inline-flex items-center gap-2 text-sm font-semibold transition-colors"
        >
          <svg
            aria-hidden="true"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M19 12H5M11 5l-7 7 7 7"></path>
          </svg>
          Toutes les réalisations
        </a>
      </div>
    </nav>
  </article>
</BaseLayout>
