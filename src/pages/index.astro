---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero/hero.jpg';
import ServicesPreview from '../components/sections/ServicesPreview.astro';
import EconomiesSection from '../components/sections/EconomiesSection.astro';
import ProjetsRecents from '../components/sections/ProjetsRecents.astro';
import SubventionsTeaser from '../components/sections/SubventionsTeaser.astro';
import Temoignages from '../components/sections/Temoignages.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
---

<BaseLayout
  title="Isolation EDKA — Spécialiste en isolation à Saint-Georges-de-Beauce"
  description="Uréthane giclé, cellulose, fibre de verre. Économies de chauffage jusqu'à 40 %. Subventions Rénoclimat, LogisVert et Chauffez vert admissibles. Soumission gratuite en Beauce."
  transparentHeader={true}
>
  <section class="dark text-foreground relative isolate overflow-hidden">
    <Image
      src={heroImage}
      alt="Flotte d'Isolation EDKA en Beauce — camions et remorques en hiver"
      class="hero-image absolute inset-0 -z-10 h-full w-full object-cover"
      style="object-position: 50% 65%;"
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-950/55 via-slate-950/40 to-slate-950/85"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-t from-slate-950 to-transparent"
      aria-hidden="true"
    >
    </div>

    <div
      class="container-page hero-stagger flex min-h-[78svh] flex-col justify-end pt-32 pb-20 sm:min-h-[82svh] sm:pt-40 sm:pb-24 lg:min-h-[85svh]"
    >
      <p class="text-[color:var(--color-brand-300)] text-sm font-semibold tracking-widest uppercase">
        Saint-Georges-de-Beauce · Chaudière-Appalaches
      </p>
      <h1
        class="font-display mt-4 max-w-3xl text-4xl leading-[1.05] font-bold drop-shadow-lg sm:text-5xl lg:text-6xl xl:text-7xl"
      >
        Isolation qui tient tête à l'hiver.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-200 drop-shadow">
        Uréthane giclé, cellulose, fibre de verre. Économies de chauffage jusqu'à
        <span class="text-[color:var(--color-brand-300)] font-semibold">40 %</span>
        et programmes de subventions admissibles.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="/contact"
          class="bg-[color:var(--color-brand-600)] hover:bg-[color:var(--color-brand-500)] focus-visible:ring-[color:var(--color-brand-300)] group inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[color:var(--color-brand-900)]/40 transition-all hover:-translate-y-0.5 hover:shadow-xl focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          Demander une soumission gratuite
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-hover:translate-x-1"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-white/30 bg-white/5 px-6 py-3 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/10"
        >
          Voir les services
        </a>
      </div>
    </div>
  </section>

  <ServicesPreview />
  <EconomiesSection />
  <ProjetsRecents />
  <SubventionsTeaser />
  <Temoignages />
  <CtaFinal />
</BaseLayout>
