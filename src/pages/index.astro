---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero/hero.jpg';
---

<BaseLayout
  title="Isolation EDKA — Spécialiste en isolation à Saint-Georges-de-Beauce"
  description="Uréthane giclé, cellulose, fibre de verre. Économies de chauffage jusqu'à 40 %. Subventions Rénoclimat admissibles. Soumission gratuite."
  transparentHeader={true}
>
  {/* Hero plein écran sombre — fondations seulement, sera étoffé à l'Étape 3.2 */}
  <section class="dark text-foreground relative isolate flex min-h-[100svh] items-end overflow-hidden">
    <Image
      src={heroImage}
      alt="Chantier d'isolation Isolation EDKA"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-950/40 via-slate-950/60 to-slate-950/95"
    >
    </div>

    <div class="container-page pt-32 pb-16 sm:pt-40 sm:pb-24">
      <p class="text-[color:var(--color-brand-300)] text-sm font-semibold tracking-widest uppercase">
        Saint-Georges-de-Beauce · Chaudière-Appalaches
      </p>
      <h1
        class="font-display mt-4 max-w-3xl text-4xl leading-[1.05] font-bold sm:text-5xl lg:text-6xl"
      >
        Isolation qui tient tête à l'hiver.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-200">
        Uréthane giclé, cellulose, fibre de verre. Économies de chauffage jusqu'à
        <span class="text-[color:var(--color-brand-300)] font-semibold">40 %</span>
        et programmes de subventions admissibles.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="/contact"
          class="bg-[color:var(--color-brand-600)] hover:bg-[color:var(--color-brand-500)] focus-visible:ring-[color:var(--color-brand-300)] inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 text-base font-semibold text-white transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          Demander une soumission gratuite
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-white/30 bg-white/5 px-6 py-3 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/10"
        >
          Voir les services
        </a>
      </div>
    </div>
  </section>

  {/* Placeholder pour le reste — sera étoffé à l'Étape 3.2 */}
  <section class="container-page py-24 sm:py-32">
    <h2 class="font-display text-3xl font-bold sm:text-4xl">Étape 3.1 — Foundations en place</h2>
    <p class="text-muted-foreground mt-3 max-w-2xl">
      Header sticky, Footer, design tokens, polices Inter + Space Grotesk, navigation 6 pages : ✓.
      Le contenu de la page d'accueil (services, économies, projets, témoignages) sera ajouté à
      l'Étape 3.2.
    </p>
  </section>
</BaseLayout>
