---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { iconPaths } from '../lib/icons';

const services = (await getCollection('services')).sort((a, b) => a.data.ordre - b.data.ordre);
---

<BaseLayout
  title="Services d'isolation — Isolation EDKA"
  description="Uréthane giclé, cellulose soufflée, fibre de verre, combles, sous-sols, commercial. Toutes les techniques d'isolation pour résidentiel, commercial et industriel."
>
  <section class="bg-muted/40 border-b">
    <div class="container-page py-20 sm:py-28">
      <p class="text-[color:var(--color-brand-600)] text-sm font-semibold tracking-widest uppercase">
        Nos services
      </p>
      <h1 class="font-display mt-3 max-w-3xl text-4xl font-bold sm:text-5xl">
        Toutes les techniques d'isolation, sous un même toit.
      </h1>
      <p class="text-muted-foreground mt-4 max-w-2xl text-lg leading-relaxed">
        On choisit la solution selon le bâtiment, pas l'inverse. Voici les six familles de
        services qu'on offre — du résidentiel au commercial, en passant par l'agricole et
        l'industriel.
      </p>
      <nav aria-label="Aller à un service" class="mt-8">
        <ul class="flex flex-wrap gap-2">
          {
            services.map((s) => (
              <li>
                <a
                  href={`#${s.id}`}
                  class="border-border bg-card hover:border-[color:var(--color-brand-400)] hover:text-[color:var(--color-brand-600)] inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium transition-colors"
                >
                  {s.data.titre}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </section>

  {
    services.map(async (service, idx) => {
      const { Content } = await render(service);
      const photoOnRight = idx % 2 === 0;
      return (
        <section id={service.id} class:list={[idx % 2 === 0 ? 'bg-background' : 'bg-muted/30']}>
          <div class="container-page py-20 sm:py-28">
            <div class="grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
              <div class:list={[photoOnRight ? 'lg:order-1' : 'lg:order-2']}>
                <div class="flex items-center gap-4">
                  <span
                    class="bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-600)] inline-flex h-12 w-12 items-center justify-center rounded-lg"
                    aria-hidden="true"
                  >
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d={iconPaths[service.data.icone]} />
                    </svg>
                  </span>
                  {service.data.valeurR && (
                    <span class="border-border bg-card text-foreground inline-flex items-center rounded-md border px-3 py-1 font-mono text-xs font-semibold">
                      {service.data.valeurR}
                    </span>
                  )}
                  {service.data.admissibleSubvention && (
                    <span class="bg-[color:var(--color-brand-100)] text-[color:var(--color-brand-800)] inline-flex items-center rounded-md px-3 py-1 text-xs font-semibold">
                      ✓ Admissible Rénoclimat
                    </span>
                  )}
                </div>
                <h2 class="font-display mt-5 text-3xl font-bold sm:text-4xl">
                  {service.data.titre}
                </h2>
                <p class="text-muted-foreground mt-3 text-lg leading-relaxed">
                  {service.data.descriptionCourte}
                </p>
                <div class="prose prose-slate text-foreground/90 mt-5 max-w-none text-base leading-relaxed">
                  <Content />
                </div>
                <div class="mt-8 grid gap-6 sm:grid-cols-2">
                  <div>
                    <h3 class="font-display text-sm font-semibold tracking-wide uppercase">
                      Avantages
                    </h3>
                    <ul class="mt-3 space-y-2 text-sm">
                      {service.data.avantages.map((avantage) => (
                        <li class="flex gap-2">
                          <svg
                            class="text-[color:var(--color-brand-600)] mt-0.5 h-4 w-4 flex-none"
                            aria-hidden="true"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M20 6 9 17l-5-5" />
                          </svg>
                          <span>{avantage}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h3 class="font-display text-sm font-semibold tracking-wide uppercase">
                      Applications typiques
                    </h3>
                    <ul class="mt-3 space-y-2 text-sm">
                      {service.data.applications.map((application) => (
                        <li class="flex gap-2">
                          <svg
                            class="text-[color:var(--color-brand-400)] mt-0.5 h-4 w-4 flex-none"
                            aria-hidden="true"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <circle cx="12" cy="12" r="10" />
                            <path d="m9 12 2 2 4-4" />
                          </svg>
                          <span>{application}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>

              {service.data.photo && (
                <div class:list={[photoOnRight ? 'lg:order-2' : 'lg:order-1']}>
                  <div class="aspect-4/3 overflow-hidden rounded-2xl shadow-xl ring-1 ring-black/5">
                    <Image
                      src={service.data.photo}
                      alt={service.data.photoAlt ?? service.data.titre}
                      widths={[600, 900, 1200]}
                      sizes="(min-width: 1024px) 45vw, 100vw"
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                </div>
              )}
            </div>
          </div>
        </section>
      );
    })
  }

  <section class="dark text-foreground bg-background">
    <div class="container-page py-20 sm:py-24">
      <div class="grid gap-8 lg:grid-cols-[2fr_1fr] lg:items-center">
        <div>
          <h2 class="font-display text-3xl font-bold sm:text-4xl">
            Pas certain quelle technique convient à votre projet ?
          </h2>
          <p class="mt-3 text-lg text-slate-300">
            On évalue gratuitement votre situation et on recommande la solution qui maximise votre
            performance et vos subventions.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col lg:justify-end">
          <a
            href="/contact"
            class="bg-[color:var(--color-brand-500)] hover:bg-[color:var(--color-brand-400)] inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 text-base font-semibold text-slate-950 transition-colors"
          >
            Demander une soumission
          </a>
          <a
            href="/subventions"
            class="inline-flex items-center justify-center gap-2 rounded-md border border-white/30 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
          >
            Voir les subventions
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
