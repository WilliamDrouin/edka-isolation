---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import ContactInfo from '../components/sections/ContactInfo.astro';
---

<BaseLayout
  title="Contact — Isolation EDKA"
  description="Demandez votre soumission gratuite. Isolation résidentielle, commerciale ou agricole dans la région de Saint-Georges et toute la Chaudière-Appalaches."
>
  <section class="bg-muted/40 border-b">
    <div class="container-page py-20 sm:py-24">
      <p class="text-[color:var(--color-brand-600)] text-sm font-semibold tracking-widest uppercase">
        Contact
      </p>
      <h1 class="font-display mt-3 max-w-3xl text-4xl font-bold sm:text-5xl">
        Demandez votre soumission gratuite.
      </h1>
      <p class="text-muted-foreground mt-4 max-w-2xl text-lg leading-relaxed">
        Décrivez-nous votre projet — résidentiel, commercial ou agricole — et nous vous
        revenons sous 24 à 48 heures avec une estimation claire et les programmes de subventions
        applicables à votre situation.
      </p>
    </div>
  </section>

  <ContactForm>
    <ContactInfo />
  </ContactForm>

  <section class="bg-muted/30 border-t">
    <div class="container-page py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-2xl font-bold sm:text-3xl">
          Préférez parler à quelqu'un en personne ?
        </h2>
        <p class="text-muted-foreground mt-3 text-base leading-relaxed">
          On organise volontiers des visites sur place pour les chantiers complexes ou les
          bâtiments commerciaux. Téléphonez-nous et on planifie un moment qui vous convient.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
